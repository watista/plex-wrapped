# Production .env snippet — copy values into your real .env on the server.
# See .env.example for the full list of variables.

APP_NAME=Plex Wrapped

# Must match the public URL users open in the browser (HTTPS in production)
PUBLIC_URL=https://wrapped.example.com

LOG_LEVEL=INFO
WRAPPED_YEAR=2025
USE_TEST_DATABASE=false

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ADMIN_SECRET=
SHARE_LINK_SECRET=

# Tautulli — use a URL reachable from the app process (see docs/DEPLOYMENT.md)
TAUTULLI_URL=http://127.0.0.1:8181
TAUTULLI_API_KEY=

# Stable UUID — generate once, keep forever
PLEX_CLIENT_ID=
PLEX_PRODUCT=PlexWrapped

USER_MAPPING_PATH=config/user_mapping.json
TELEGRAM_REQUESTS_PATH=data/telegram_requests.json
DATABASE_PATH=data/wrapped.db

# Optional notifications and analytics
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
GOOGLE_ANALYTICS_ID=

# Optional poster proxy (Plex server owner token)
PLEX_SERVER_URL=
PLEX_SERVER_TOKEN=
