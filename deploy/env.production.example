# Production .env snippet — copy values into your real .env on the server.
# See .env.example for the full list of variables.

# Application
APP_NAME=Plex Wrapped
# Must match the exact URL users open in the browser (HTTPS in production)
PUBLIC_URL=https://wrapped.example.com
LOG_LEVEL=INFO

# Activity notifications (optional — login alerts to your Telegram channel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Google Analytics measurement ID (optional)
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
WRAPPED_YEAR=2025
SESSION_MAX_AGE=604800

# Tautulli — use a URL reachable from the app process (see docs/DEPLOYMENT.md)
TAUTULLI_URL=http://127.0.0.1:8181
TAUTULLI_API_KEY=

# Stable UUID — generate once, keep forever
PLEX_CLIENT_ID=
PLEX_PRODUCT=PlexWrapped

# Admin & share links
ADMIN_SECRET=
SHARE_LINK_SECRET=
SHARE_LINK_EXPIRY_DAYS=90

# Data files (paths relative to project root or absolute)
USER_MAPPING_PATH=config/user_mapping.json
TELEGRAM_REQUESTS_PATH=data/telegram_requests.json
DATABASE_PATH=data/wrapped.db
TEST_DATABASE_PATH=data/wrapped_test.db
USE_TEST_DATABASE=false
WRAPPED_TEST_FIXTURE_PATH=data/fixtures/wrapped_test.json
WRAPPED_TEST_USERS_PATH=data/fixtures/test_users.json

# Optional: Plex server token for poster proxy (server owner's token)
PLEX_SERVER_URL=
PLEX_SERVER_TOKEN=

# Optional TMDB — favorite-actor slide and poster fallbacks
TMDB_API_KEY=

# Slide music (resolved at compute time — ffmpeg + yt-dlp on compute host)
MUSIC_ENABLED=true
MUSIC_DOWNLOAD_ENABLED=true
AUDIO_CACHE_PATH=data/audio/cache
# Per-title YouTube overrides for theme slides (copy config/music_overrides.json.example)
# MUSIC_OVERRIDES_PATH=config/music_overrides.json
# Optional path to ffmpeg binary or directory (for mp3 conversion via yt-dlp)
FFMPEG_LOCATION=

# Optional Spotify — refines soundtrack search before YouTube
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional Cursor AI — Dutch punchlines during compute (cursor-agent on compute host)
CURSOR_AI_ENABLED=false
CURSOR_API_KEY=
CURSOR_MODEL=auto
CURSOR_TIMEOUT_SECONDS=120
# Working directory the local agent runs against (empty = project root)
CURSOR_AGENT_CWD=
