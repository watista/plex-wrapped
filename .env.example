# Application
APP_NAME=Plex Wrapped
# Must match the exact URL you open in the browser (scheme + host + port)
PUBLIC_URL=http://localhost:8000
LOG_LEVEL=INFO

# Activity notifications (optional — login alerts to your Telegram channel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Google Analytics measurement ID (optional)
GOOGLE_ANALYTICS_ID=G-XZ4KKB4KXF

SECRET_KEY=change-me-to-a-long-random-string
WRAPPED_YEAR=2025
SESSION_MAX_AGE=604800

# Tautulli
TAUTULLI_URL=http://localhost:8181
TAUTULLI_API_KEY=your-tautulli-api-key

# Plex OAuth (generate a UUID for client_id)
PLEX_CLIENT_ID=your-plex-client-uuid
PLEX_PRODUCT=PlexWrapped

# Admin & share links
ADMIN_SECRET=change-me-admin-secret
SHARE_LINK_SECRET=change-me-share-link-secret
SHARE_LINK_EXPIRY_DAYS=90

# Data files (paths relative to project root or absolute)
USER_MAPPING_PATH=config/user_mapping.json
TELEGRAM_REQUESTS_PATH=data/telegram_requests.json
DATABASE_PATH=data/wrapped.db
TEST_DATABASE_PATH=data/wrapped_test.db
USE_TEST_DATABASE=false
WRAPPED_TEST_FIXTURE_PATH=data/fixtures/wrapped_test.json
WRAPPED_TEST_USERS_PATH=data/fixtures/test_users.json

# Optional: Plex server token for poster proxy (server owner's token)
PLEX_SERVER_URL=
PLEX_SERVER_TOKEN=

# TMDB API key — posters when Plex thumbs 404, and favorite-actor credits/photos
# (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# Background music — resolved at compute time via yt-dlp + ffmpeg (see scripts/setup_audio_placeholders.py)
MUSIC_ENABLED=true
MUSIC_DOWNLOAD_ENABLED=true
AUDIO_CACHE_PATH=data/audio/cache
AUDIO_GENRE_PATH=static/audio/genres
AUDIO_YEAR_PATH=static/audio/year
# Optional path to ffmpeg binary or directory (for mp3 conversion via yt-dlp)
FFMPEG_LOCATION=

# Spotify API — refines soundtrack track names before YouTube search
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Cursor AI — generates dynamic copy while computing wrapped data.
# Uses the Cursor Python SDK (local runtime), so the `cursor-agent` runtime
# must be installed on the machine that runs scripts/compute_wrapped.py.
# Get an API key at https://cursor.com/dashboard (Integrations / API Keys).
CURSOR_AI_ENABLED=false
CURSOR_API_KEY=
CURSOR_MODEL=auto
CURSOR_TIMEOUT_SECONDS=120
# Working directory the local agent runs against (empty = project root)
CURSOR_AGENT_CWD=
